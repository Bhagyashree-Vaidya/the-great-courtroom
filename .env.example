# Backend environment variables.
# Local dev: copy to `.env` and fill in. Production (Fly): set with `fly secrets set`.

# Required. Your OpenRouter API key (https://openrouter.ai/settings/keys).
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Production only. Shared password that gates the app. Leave UNSET locally
# to disable the gate during development.
COUNCIL_PASSWORD=

# Production only. Comma-separated allowed frontend origins for CORS.
# Example: https://council.shreevaidya.com
# Defaults to localhost when unset.
ALLOWED_ORIGINS=
